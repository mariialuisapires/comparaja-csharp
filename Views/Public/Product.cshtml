@using System.Text.Json
@{
    var product    = (ComparadorPrecos.Domain.Product)ViewBag.Product;
    var listings   = (IReadOnlyList<ListingComparisonItem>)ViewBag.Listings;
    var history    = (Dictionary<string, List<PricePoint>>)ViewBag.History;
    var bestPriced = listings.FirstOrDefault(l => l.CurrentPrice.HasValue);
    ViewBag.Title  = product.DisplayName + " — ComparaJá";

    var historyJson = JsonSerializer.Serialize(history
        .Select(kv => new { label = kv.Key, data = kv.Value.Select(p => new { x = p.X, y = p.Y }) }));
}
<div class="product-detail-wrap">
    <a class="back-link" href="/public">← Voltar</a>
    <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:1rem;margin-bottom:2rem;flex-wrap:wrap">
        <h1 class="product-detail-title" style="margin-bottom:0;flex:1">@product.DisplayName</h1>
        <button class="detail-fav-btn"
                data-product-id="@product.Id"
                data-product-name="@product.DisplayName"
                data-product-price="@(bestPriced?.CurrentPrice?.ToString(System.Globalization.CultureInfo.InvariantCulture) ?? "")"
                data-product-site="@(bestPriced?.Site ?? "")"
                data-product-stores="@listings.Count"
                data-product-image="@(bestPriced?.ImageUrl ?? listings.FirstOrDefault(l => l.ImageUrl != null)?.ImageUrl ?? "")">
            <span class="detail-fav-icon">♡</span><span>Favoritar</span>
        </button>
    </div>

    @if (!listings.Any())
    {
        <p class="empty-state">Nenhuma listagem disponível no momento.</p>
    }
    else
    {
        <section class="comparison-section">
            <h2>Comparar preços</h2>
            <div class="listing-rows">
                @foreach (var l in listings)
                {
                    <div class="listing-row">
                        @if (l.ImageUrl is not null)
                        {
                            <img class="listing-thumb" src="@l.ImageUrl" alt="@l.Title" loading="lazy" />
                        }
                        <div class="listing-info">
                            <div style="display:flex;align-items:center;gap:.5rem;flex-wrap:wrap">
                                <span class="site-badge site-badge--@l.Site">@l.Site</span>
                                @if (l == bestPriced)
                                {
                                    <span class="best-badge">✓ Melhor preço</span>
                                }
                            </div>
                            <a class="listing-title" href="@l.Url" target="_blank" rel="noopener">@l.Title</a>
                            @if (l.Seller is not null)
                            {
                                <span class="listing-seller">Vendido por @l.Seller</span>
                            }
                        </div>
                        <div class="listing-price">
                            @if (l.CurrentPrice.HasValue)
                            {
                                <span class="price-current">R$ @l.CurrentPrice.Value.ToString("N2")</span>
                                @if (l.OriginalPrice.HasValue)
                                {
                                    <span class="price-original">R$ @l.OriginalPrice.Value.ToString("N2")</span>
                                }
                            }
                            else
                            {
                                <span class="price-current card-price--na">Verificar preço</span>
                            }
                            <a class="listing-go-btn" href="@l.Url" target="_blank" rel="noopener">
                                Ir à loja →
                            </a>
                        </div>
                    </div>
                }
            </div>
        </section>
    }

    @if (history.Any())
    {
        <section class="chart-section">
            <h2>Histórico de preços</h2>
            <div class="chart-wrapper">
                <div class="chart-periods">
                    <button class="period-btn active" data-days="40">40 dias</button>
                    <button class="period-btn" data-days="90">3 meses</button>
                    <button class="period-btn" data-days="180">6 meses</button>
                    <button class="period-btn" data-days="365">1 ano</button>
                </div>
                <canvas id="priceChart"></canvas>
            </div>
        </section>
    }
</div>

@if (history.Any())
{
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/luxon@@3/build/global/luxon.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chartjs-adapter-luxon@@1"></script>
    <script>
    const ALL_DATASETS = @Html.Raw(historyJson);
    const PALETTE = ['#2563EB','#10B981','#F59E0B','#EF4444','#8B5CF6','#EC4899'];
    let chart;

    function buildDatasets(days) {
        const cutoff = luxon.DateTime.now().minus({ days }).toISODate();
        return ALL_DATASETS.map((ds, i) => ({
            label: ds.label,
            data: ds.data.filter(p => p.x >= cutoff).map(p => ({ x: p.x, y: p.y })),
            borderColor: PALETTE[i % PALETTE.length],
            backgroundColor: PALETTE[i % PALETTE.length] + '14',
            tension: 0.35,
            pointRadius: 3,
            fill: false,
        }));
    }

    function render(days) {
        if (chart) chart.destroy();
        const ctx = document.getElementById('priceChart').getContext('2d');
        chart = new Chart(ctx, {
            type: 'line',
            data: { datasets: buildDatasets(days) },
            options: {
                interaction: { mode: 'index', intersect: false },
                scales: {
                    x: { type: 'time', time: { unit: 'day' },
                         grid: { color: 'rgba(0,0,0,.04)' },
                         ticks: { color: '#94A3B8', font: { size: 11 } } },
                    y: { grid: { color: 'rgba(0,0,0,.04)' },
                         ticks: { color: '#94A3B8', font: { size: 11 },
                                  callback: v => 'R$ ' + v.toLocaleString('pt-BR') } }
                },
                plugins: {
                    legend: { position: 'bottom',
                              labels: { usePointStyle: true, pointStyle: 'circle',
                                        font: { size: 12 }, padding: 20 } },
                    tooltip: {
                        callbacks: {
                            label: ctx => ' R$ ' + ctx.parsed.y.toLocaleString('pt-BR', { minimumFractionDigits: 2 })
                        }
                    }
                }
            }
        });
    }

    document.querySelectorAll('.period-btn').forEach(btn => {
        btn.addEventListener('click', () => {
            document.querySelectorAll('.period-btn').forEach(b => b.classList.remove('active'));
            btn.classList.add('active');
            render(+btn.dataset.days);
        });
    });

    render(40);
    </script>
}
